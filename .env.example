# ─── Stakeout environment variables ───────────────────────────────────────
# TEMPLATE — copy to .env.local for local dev; set these in Vercel for prod.

# Anthropic API key — https://console.anthropic.com (Settings → API keys)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Neon Postgres pooled connection string
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Nostr Wallet Connect string from your Alby wallet (no KYC). In Alby:
# create an app connection with make_invoice + lookup_invoice permissions,
# then copy the nostr+walletconnect://... string.
NWC_URL=nostr+walletconnect://...

# Optional: override the scan model (defaults to cheap Haiku).
# STAKEOUT_MODEL=claude-sonnet-4-6
